const app = require("../app");
const debug = require("debug")("server-semina:server");
const http = require("http");
const socketManager = require("../resource/helper/socket-server");

// import package db
const db = require("../database");

/**
 * Get port from environment and store in Express.
 */
const port = normalizePort(process.env.PORT || "3000");
app.set("port", port);

/**
 * Create HTTP server.
 */
const server = http.createServer(app);

/**
 * Initialize Socket.io with Redis Adapter
 * Kita panggil fungsi ini di sini agar 'io' menempel pada server yang benar.
 */
socketManager(server);

/**
 * Database Connection & Server Activation
 */

// Menangani error koneksi MongoDB
db.on("error", function (err) {
  console.error("❌ Connection error: tidak bisa tersambung ke mongodb");
});

/**
 * Pastikan database terhubung sebelum server mulai mendengarkan (listen)
 */
db.once("open", function () {
  console.log("✅ Connected to MongoDB");

  // Menjalankan server
  server.listen(port);
  server.on("error", onError);
  server.on("listening", onListening);
});

/**
 * Normalize a port into a number, string, or false.
 */
function normalizePort(val) {
  const port = parseInt(val, 10);

  if (isNaN(port)) {
    // named pipe
    return val;
  }

  if (port >= 0) {
    // port number
    return port;
  }

  return false;
}

/**
 * Event listener for HTTP server "error" event.
 */
function onError(error) {
  if (error.syscall !== "listen") {
    throw error;
  }

  const bind = typeof port === "string" ? "Pipe " + port : "Port " + port;

  // handle specific listen errors with friendly messages
  switch (error.code) {
    case "EACCES":
      console.error(bind + " requires elevated privileges");
      process.exit(1);
      break;
    case "EADDRINUSE":
      console.error(bind + " is already in use");
      process.exit(1);
      break;
    default:
      throw error;
  }
}

/**
 * Event listener for HTTP server "listening" event.
 */
function onListening() {
  const addr = server.address();
  const bind = typeof addr === "string" ? "pipe " + addr : "port " + addr.port;
  console.log(`🚀 Server running on ${bind}`);
  debug("Listening on " + bind);
}
